{
  "name": "brick-wall-detector",
  "version": "1.2.0",
  "description": "红砖墙病害智能检测与修缮报告系统",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node backend/server.js",
    "dev:server:debug": "DEBUG_MODE=1 NODE_ENV=development node --trace-warnings backend/server.js",
    "dev:client": "vite --config frontend/vite.config.ts",
    "build": "vite build --config frontend/vite.config.ts",
    "start": "NODE_ENV=production node backend/server.js",
    "start:debug": "DEBUG_MODE=1 NODE_ENV=development node --trace-warnings backend/server.js",
    "preview": "vite preview --config frontend/vite.config.ts"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "echarts": "^5.4.3",
    "element-plus": "^2.4.4",
    "express": "^4.18.2",
    "html2canvas": "^1.4.1",
    "image-size": "^2.0.2",
    "jspdf": "^2.5.1",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.34.5",
    "vue": "^3.4.0",
    "vue-echarts": "^6.6.1",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@vitejs/plugin-vue": "^5.0.2",
    "concurrently": "^8.2.2",
    "typescript": "~5.3.3",
    "vite": "^5.0.10",
    "vue-tsc": "^1.8.25"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
