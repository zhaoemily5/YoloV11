# ============================================================
#  红砖墙病害智能检测系统 — 环境变量配置
#  复制此文件为 .env 并填入实际值: cp .env.example .env
# ============================================================

# 服务端口
PORT=3080

# ==================== 目标检测模型（YOLOv11）====================
# 阿里云 PAI-EAS 在线推理服务
# 未配置时系统自动进入演示模式（使用内置案例数据）
# PAI_API_URL=http://<service-name>.<region>.pai-eas.aliyuncs.com/api/predict/<service-name>
# PAI_API_TOKEN=<your-eas-token>

# ==================== AI 大模型服务 ====================
# 优先级: PAI-LLM (1) > SiliconFlow (2) > 规则引擎 (3)

# --- SiliconFlow API（测试环境）---
SILICONFLOW_URL=https://api.siliconflow.cn/v1/chat/completions
SILICONFLOW_KEY=<your-siliconflow-api-key>
SILICONFLOW_MODEL=Qwen/Qwen3-8B

# --- 阿里云 PAI 大模型（生产环境，优先级高于 SiliconFlow）---
# PAI_LLM_URL=<your-pai-llm-endpoint>
# PAI_LLM_TOKEN=<your-pai-llm-token>
